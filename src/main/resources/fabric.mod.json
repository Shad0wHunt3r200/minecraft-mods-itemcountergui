{
	"schemaVersion": 1,
	"id": "mace-utils-hud",
	"version": "${version}",
	"name": "Mace Utils HUD",
	"description": "Gives a fixed position HUD for counting the number of windcharges, pearls and elytra durability",
	"authors": [
		"Shad0wHunt3r"
	],
	"contact": {
		"sources": "https://github.com/Shad0wHunt3r200/minecraft-mods-itemcountergui"
	},
	"license": "CC0-1.0",
	"icon": "assets/mace-utils-hud/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.shad0whunt3r.maceutils.MaceUtilsHUD"
		],
		"client": [
			"com.shad0whunt3r.maceutils.client.MaceUtilsHUDClient"
		],
		"modmenu": [
			"com.shad0whunt3r.maceutils.client.ModMenuIntegration"
		]
	},
	"mixins": [
		"mace-utils-hud.mixins.json",
		{
			"config": "mace-utils-hud.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"yet_another_config_lib_v3": "*",
		"modmenu": "*"
	}
}